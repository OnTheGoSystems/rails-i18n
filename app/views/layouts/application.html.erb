<!DOCTYPE html>
<html>
  <head>
    <title>SampleRailsI18n</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-locale="<%= I18n.locale %>">
    <ul>
      <% %w[en es de].each do |lang_code| %>
        <li>
          <%= link_to lang_code, time_display_path(locale: lang_code) %>
        </li>
      <% end %>
    </ul>
    <%= yield %>
  </body>
</html>
